generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Neon：运行时用语「Pooled」连接串（主机名常含 -pooler）
  url       = env("DATABASE_URL")
  // 迁移与 introspect 用「Direct」直连串（主机名一般不含 -pooler）；避免在 Vercel 上对 pooler 跑 migrate 易 P1001
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  emailVerified Boolean @default(false)
  verifyToken   String?
  verifyTokenExpires DateTime?

  entries  Entry[]
  comments Comment[]
  createdAt DateTime @default(now())
}

model Entry {
  id        String   @id @default(cuid())
  title     String
  content   String
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments  Comment[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([authorId])
}

model Comment {
  id             String   @id @default(cuid())
  entryId        String
  entry          Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  authorId       String
  author         User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  paragraphIndex Int
  content        String
  createdAt      DateTime @default(now())

  @@index([entryId, paragraphIndex])
}
