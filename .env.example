# PostgreSQL（本地 Docker / Neon / Supabase / Railway 等）
# 示例（Neon）：postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/diary?schema=public"

# 线上访问地址（邮件验证链接、生产环境必填）
APP_BASE_URL="https://你的域名.vercel.app"

# iron-session，至少 32 个字符
SESSION_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# —— 先发版、后做邮箱验证时建议开启（生产接入 SMTP 后务必改为 false 或删除）——
# SKIP_EMAIL_VERIFICATION="true"

# 配置 SMTP 后发送真实验证邮件；与上一项二选一：要正式验证则关 SKIP、配 SMTP
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="you@example.com"
# SMTP_PASS="your-password"
# SMTP_FROM="日记站 <noreply@example.com>"
# SMTP_SECURE="false"

# ========== 部署提示（Vercel）==========
# 1. 在 Neon 等创建数据库，把 DATABASE_URL、SESSION_SECRET、APP_BASE_URL 配到 Vercel Environment Variables。
# 2. 先发版可设 SKIP_EMAIL_VERIFICATION=true，用户注册后可直接登录。
# 3. Build Command 建议：npx prisma migrate deploy && prisma generate && next build
#    （本地打包不含 migrate deploy，避免没装数据库时 build 失败）
